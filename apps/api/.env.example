# --- Games ---
BOUNCER_SERVER_URL="http://localhost:4001" # TODO:: Don't forget to change for prod
GAME_TICKET_SECRET="MitochondriaIsThePowerhouseOfTheCell"


# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flowt_dev?schema=public"
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/flowt_test?schema=public"



# --- OAuth ---
SESSION_SECRET="secret"
GOOGLE_CLIENT_ID="something.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="secret from google"
GOOGLE_CALLBACK_URL="domain:port/api/auth/google/callback"
DISCORD_CLIENT_ID="your discord client id"
DISCORD_CLIENT_SECRET="your discord client secret"
DISCORD_CALLBACK_URL="domain:port/api/auth/discord/callback"


# --- Chat / CORS ---
CHAT_TOKEN_SECRET="replace-with-random-secret"
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,https://TODO.UPDATEDOMAINNAME.COM"



# --- AWS ---
