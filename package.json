{
  "name": "cup",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "deploy:api": "pnpm --filter @cup/api run deploy",
    "deploy:bouncer": "pnpm --filter @cup/bouncer-server run deploy",
    "deploy:web": "pnpm --filter @cup/web run deploy",
    "deploy": "pnpm run deploy:api && pnpm run deploy:bouncer && pnpm run deploy:web",
    "dev": "pnpm -r --parallel --filter ./apps/api --filter ./apps/web --filter \"./games/bouncer/*\" --filter ./packages/shared run start:dev",
    "dev:api": "pnpm --filter ./apps/api start:dev",
    "test:api": "pnpm --filter ./apps/api test",
    "dev:web": "pnpm --filter ./apps/web start:dev",
    "build:web": "pnpm --filter ./apps/web build",
    "build:types": "pnpm --filter ./packages/shared build && pnpm --filter ./games/bouncer/shared build && pnpm --filter ./games/bouncer/engine build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "pnpm -r format",
    "format:fix": "pnpm -r format:fix",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --parallel --filter ./apps/api test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.26.1"
}
